# Configuration for AI Engineering Fluency VS Code Extension
# This project uses pnpm as the package manager.

# Use pnpm-lock.yaml for reproducible builds
# - Use `pnpm install --frozen-lockfile` for installing dependencies (equivalent of npm ci)
# - Use `pnpm install` only when adding/updating dependencies
# - CI/CD workflows use `pnpm install --frozen-lockfile` exclusively

# Do not use legacy peer dependency resolution
# Some dependencies have peer dependencies we don't use (e.g., react from @vscode/webview-ui-toolkit)
# This is expected and does not affect functionality
legacy-peer-deps=false

# Save exact versions (no ^ or ~ prefixes) when adding new dependencies
# This ensures maximum reproducibility
save-exact=true

# Disable funding prompts for more stable non-interactive runs
fund=false
